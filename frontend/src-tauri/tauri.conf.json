{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Neuro Agent",
  "version": "0.1.0",
  "identifier": "com.neuroagent.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "Neuro Agent",
        "width": 1280,
        "height": 800,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "externalBin": [
      "binaries/neuro-agent-backend"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "nsis": {
        "installMode": "currentUser",
        "languages": ["English", "Spanish"]
      },
      "wix": {
        "language": "en-US"
      }
    },
    "android": {
      "debugApplicationIdSuffix": ".debug"
    }
  }
}
